      "bubbles": {
        "incoming": "#E9E9EB",
        "outgoing": "#007AFF",
        "incomingText": "#000000",
        "outgoingText": "#FFFFFF",
        "incomingBorder": "#E9E9EB",
        "outgoingBorder": "#007AFF"
      },
      "inbox": {
        "background": "#FFFFFF",
        "rowBackground": "#FFFFFF",
        "headerBackground": "#FFFFFF",
        "titleText": "#000000",
        "primaryText": "#000000",
        "secondaryText": "#8E8E93",
        "timestampText": "#8E8E93",
        "divider": "#E5E5EA",
        "unreadDot": "#007AFF",
        "avatarFallbackBackground": "#8EA2D8",
        "searchBackground": "#F2F2F7",
