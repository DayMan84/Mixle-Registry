{
  "id": "apple-messages",
  "version": "1.0.0",
  "label": "Apple Messages",
  "description": "Bright iOS-style bubbles and neutrals with pinned grid inbox.",
  "publisher": "mixle",
  "minAppVersion": "1.0.0",
  "capabilities": {
    "inboxLayout": "apple",
    "avatarShape": "circle",
    "bubbleStyle": "ios-tail",
    "supportsColorMode": true,
    "supportsAccentPreset": false,
    "supportsPixelateAvatars": true,
    "supportsCompactConversationList": true,
    "supportsConversationBubbleColors": false,
    "usesPinnedGridLayout": true,
    "forcesDarkMode": false,
    "pixelFrameBorders": false
  },
  "preview": {
    "imageUrl": "preview.png",
    "background": "#FFFFFF",
    "surface": "#FFFFFF",
    "outgoingBubble": "#007AFF",
    "incomingBubble": "#E9E9EB",
    "accent": "#007AFF"
  },
  "tokens": {
    "light": {
      "background": "#FFFFFF",
      "surface": "#FFFFFF",
      "surfaceSecondary": "#F2F2F7",
      "border": "#D1D1D6",
